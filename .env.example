# ============================================================
# Variables de entorno - Sistema de Gestión de Matrícula
# ------------------------------------------------------------
# Copia este archivo a ".env" para desarrollo local:
#     cp .env.example .env
#
# En Render NO se sube el .env: estas variables se definen en
# el dashboard del servicio (Environment).
# ============================================================

# Driver de base de datos: pgsql (Supabase) | mysql (local)
DB_CONNECTION=pgsql

# --- Conexión a Supabase (Project Settings -> Database) ---
# Usa el "Connection pooler" (puerto 6543) para apps web.
DB_HOST=aws-0-us-east-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.xxxxxxxxxxxxxxxxxxxx
DB_PASSWORD=TU_PASSWORD_DE_SUPABASE
DB_SSLMODE=require

# ------------------------------------------------------------
# Ejemplo para MySQL local (XAMPP/MAMP):
# DB_CONNECTION=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=InstitutoIdiomas
# DB_USER=root
# DB_PASSWORD=
# ------------------------------------------------------------
